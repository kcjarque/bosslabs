# Copy this file to .env.local and fill in your values.
# Both files have the same variables. .env.local is gitignored.

# ── Admin (login at /admin/login) ─────────────────────────────────────────
ADMIN_PASSWORD=bosslabs
ADMIN_COOKIE_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# ── Public site URL (no trailing slash) ───────────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Webinar — BOOTSTRAP ONLY ──────────────────────────────────────────────
# These are fallbacks used on a fresh deploy before you've touched /admin/settings.
# Once you save any of these in the admin UI, the DB value wins from then on.
# You can leave them blank in prod and just edit live.
NEXT_PUBLIC_WEBINAR_DATE=To Be Announced
NEXT_PUBLIC_WEBINAR_TIME=8:00 PM
NEXT_PUBLIC_WEBINAR_TZ=PHT
NEXT_PUBLIC_WEBINAR_STARTS_AT_ISO=

# ── Supabase (signups + templates + settings storage) ─────────────────────
# Supabase dashboard → Settings → API → Project URL + service_role secret
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# Optional — only needed for `npm run db:scaffold` (one-shot migration)
# Generate at https://supabase.com/dashboard/account/tokens
SUPABASE_ACCESS_TOKEN=

# ── Xendit (paid checkout, leave blank for demo mode) ────────────────────
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# ── Vercel Cron (reminders + replay scheduler) ───────────────────────────
# Required in production. Vercel Cron sends Authorization: Bearer ${CRON_SECRET}
# on every scheduled invocation; our /api/cron/* routes reject anything else
# so the open internet can't trigger mass email/SMS sends.
# Generate with: node -e "console.log(crypto.randomBytes(32).toString('hex'))"
CRON_SECRET=

# ── Meta Pixel + Conversions API (CAPI) ──────────────────────────────────
# Browser pixel + server-side event API. Server events dedupe with pixel
# events using event_id so Meta counts each conversion once across both
# sources. Without this, ad blockers + iOS ATT drop ~40% of conversions.
#
# Where to find them:
#   Pixel ID: https://business.facebook.com → Events Manager → Data Sources → Pixel
#   Access Token: Events Manager → your pixel → Settings → Conversions API →
#     "Generate access token" (long-lived system user token preferred)
#
# Leave blank to disable — code falls back to a no-op log so dev/preview
# never breaks on missing keys.
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=
# Optional — set to your test event code while verifying events in Meta's
# "Test Events" tab. Leave blank in production or events won't reach the
# real attribution pipeline.
META_CAPI_TEST_EVENT_CODE=

# ── Optional bootstrap fallbacks ──────────────────────────────────────────
# Once /admin/settings has values for these, the DB wins. Leave blank in prod.
NEXT_PUBLIC_ZOOM_REGISTER_URL=
NEXT_PUBLIC_MESSENGER_GROUP_URL=
