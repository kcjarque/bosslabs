# Xendit — leave blank to use demo mode (skips real charge, routes directly to OTO)
XENDIT_SECRET_KEY=
XENDIT_WEBHOOK_TOKEN=

# Public base URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Webinar (used on landing pages + countdown)
NEXT_PUBLIC_WEBINAR_DATE=To Be Announced
NEXT_PUBLIC_WEBINAR_TIME=8:00 PM
NEXT_PUBLIC_WEBINAR_TZ=PHT
# ISO date the webinar starts — drives the countdown timer (fallback: +14 days)
NEXT_PUBLIC_WEBINAR_STARTS_AT_ISO=
NEXT_PUBLIC_ZOOM_REGISTER_URL=

# Messenger group link — used as the "free gift" unlock on /registered
NEXT_PUBLIC_MESSENGER_GROUP_URL=

# Admin auth — required to access /admin
ADMIN_PASSWORD=bosslabs
# Sign admin cookies. Change to anything long + random.
ADMIN_COOKIE_SECRET=

# Note: Resend, OneWaySMS, Zoom + Messenger URLs are now managed in /admin/settings,
# not via env vars. They live in data/settings.json (gitignored).
